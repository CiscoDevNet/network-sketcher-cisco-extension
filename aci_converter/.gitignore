# Generated output (kept out of version control)
Output_data/*
!Output_data/.gitkeep

# Input exports are site-specific; don't commit real APIC config exports
# (the bundled sample_export.json is the one exception, kept as an example)
Input_data/*
!Input_data/.gitkeep
!Input_data/sample_export.json

# Generated artifacts if ever written next to the script
ns_commands*.txt
ns_model_*.json
gen_*.csv
aci_inventory.csv
aci_underlay_report.md
aci_overlay_report.md
apic_export.json
\[MASTER\]*.nsm
\[L1_DIAGRAM\]*
\[L2_DIAGRAM\]*
\[L3_DIAGRAM\]*
\[L1L2L3_DIAGRAM\]*
\[DEVICE_TABLE\]*
\[AI_Context\]*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
