# Generated output (kept out of version control)
Output_data/*
!Output_data/.gitkeep

# Input exports are site-specific; don't commit real Catalyst Center exports
# (the bundled sample_*.json files are the exception, kept as examples)
Input_data/*
!Input_data/.gitkeep
!Input_data/sample_catc_export.json

